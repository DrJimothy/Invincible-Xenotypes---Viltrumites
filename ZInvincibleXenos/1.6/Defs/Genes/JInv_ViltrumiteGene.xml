<Defs>
	<GeneDef>
		<defName>JInv_VSmartGene</defName>
		<label>Smart Atom Production</label>
 		<displayCategory>Archite</displayCategory>
		<description>Carriers of this gene produce smart atoms in their body, making the impossible possible. By itself, this gene does nothing.</description>
		<iconPath>UI/Icons/Genes/Gene_GrayEyes</iconPath>
		<biostatMet>6</biostatMet>
		<biostatCpx>8</biostatCpx>
		<biostatArc>2</biostatArc>
		<displayOrderInCategory>42.35</displayOrderInCategory>
		<marketValueFactor>5</marketValueFactor>
		<exclusionTags>
			<li>SmartAtomSauce</li>
		</exclusionTags>
	</GeneDef>

	<GeneDef>
		<defName>JInv_VMetabolism</defName>
		<label>Smart Metabolism</label>
 		<displayCategory>Archite</displayCategory>
		<description>Smart atoms improve their metabolic efficiency by a ridiculous amount.</description>
		<iconPath>UI/Icons/Genes/Gene_ArchiteMetabolism</iconPath>
		<biostatCpx>66</biostatCpx>
		<biostatMet>66</biostatMet>
		<biostatArc>22</biostatArc>
		<displayOrderInCategory>42.351</displayOrderInCategory>
		<marketValueFactor>4</marketValueFactor>
		<prerequisite>JInv_VSmartGene</prerequisite>
	</GeneDef>

	<GeneDef>
		<defName>JInv_VMetabolism2</defName>
		<label>Do not use</label>
		<description>This gene has been deactivated. It would be wise to remove it from anyone who has it, as the def may be recycled for something Scourge Virus related.</description>
