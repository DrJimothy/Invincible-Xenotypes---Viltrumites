<Defs>

	<!-- Viltrumite Baseline -->

	<PawnKindDef Name="ViltrumiteFighterBase" Abstract="True">
		<race>Human</race>
		<defaultFactionDef>ViltrumEmpire</defaultFactionDef>
		<minGenerationAge>20</minGenerationAge>
		<titleSelectOne>
			<li MayRequire="Ludeon.RimWorld.Royalty">Vilt_Cadet</li>
			<li MayRequire="Ludeon.RimWorld.Royalty">Vilt_Soldier</li>
			<li MayRequire="Ludeon.RimWorld.Royalty">Vilt_Officer</li>
			<li MayRequire="Ludeon.RimWorld.Royalty">Vilt_Lieutenant</li>
			<li MayRequire="Ludeon.RimWorld.Royalty">Vilt_Captain</li>
		</titleSelectOne>
		<apparelTags>
			<li>IndustrialBasic</li>
		</apparelTags>
		<styleItemTags>
			<li>
				<tag>Soldier</tag>
				<baseWeight>1</baseWeight>
				<weightFactor>1</weightFactor>
			</li>
		</styleItemTags>
		<invNutrition>2.55</invNutrition>
		<apparelAllowHeadgearChance>0</apparelAllowHeadgearChance>
		<apparelMoney>500~1000</apparelMoney>
		<itemQuality>Legendary</itemQuality>
		<maxApparelQuality>Legendary</maxApparelQuality>
		<techHediffsChance>0.5</techHediffsChance>
		<techHediffsMoney>250~9000</techHediffsMoney>
		<useFactionXenotypes>false</useFactionXenotypes>
		<xenotypeSet>
			<xenotypeChances>
				<Jim_Viltrumite>1</Jim_Viltrumite>
			</xenotypeChances>
		</xenotypeSet>
	</PawnKindDef>

	<!-- Garbage Viltrumite -->
	<PawnKindDef ParentName="ViltrumiteFighterBase">
		<defName>Viltrumite_Fighter_Garbage</defName>
