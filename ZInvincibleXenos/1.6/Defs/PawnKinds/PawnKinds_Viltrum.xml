			<li>Nimble</li>
		</disallowedTraits>
		<skills>
			<li>
				<skill>Melee</skill>
				<range>0~6</range>
			</li>
		</skills>
		<initialWillRange>5~10</initialWillRange>
		<initialResistanceRange>10~15</initialResistanceRange>
	</PawnKindDef>

