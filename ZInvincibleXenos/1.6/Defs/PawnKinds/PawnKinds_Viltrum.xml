			<li>Apparel_BasicShirt</li>
		</apparelRequired>
		<backstoryFiltersOverride>
			<li>
				<categories>
					<li>ViltrumGarbage</li>
					<li>ViltrumChild</li>
				</categories>
			</li>
		</backstoryFiltersOverride>
		<techHediffsTags>
			<li>Advanced</li>
