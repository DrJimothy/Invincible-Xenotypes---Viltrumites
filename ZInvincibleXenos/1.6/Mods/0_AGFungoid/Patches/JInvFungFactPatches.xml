<?xml version="1.0" encoding="utf-8" ?>
<Patch>

<!-- Raids -->
<Operation Class="PatchOperationAdd">
    <xpath>Defs/FactionDef[defName="ViltrumEmpire"]/pawnGroupMakers</xpath>
    <value>
      <li>
        <!-- Speeder Attack -->
        <kindDef>Combat</kindDef>
        <commonality>1</commonality>
        <options>
          <Vilgrunt_Mycomorph>1</Vilgrunt_Mycomorph>
        </options>
      </li>
      <li>
        <!-- Speeder Attack with Viltrumite -->
        <kindDef>Combat</kindDef>
        <commonality>1</commonality>
        <options>
          <Viltrumite_Fighter_Simple>0.1</Viltrumite_Fighter_Simple>
          <Vilgrunt_Mycomorph>1</Vilgrunt_Mycomorph>
        </options>
      </li>
    </value>
</Operation>

</Patch>