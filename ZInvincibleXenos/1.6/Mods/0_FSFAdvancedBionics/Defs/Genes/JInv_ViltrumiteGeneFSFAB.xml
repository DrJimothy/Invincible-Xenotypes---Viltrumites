	<GeneDef>
		<defName>JInv_VDigestion</defName>
		<label>Smart Digestion</label>
		<description>Aided by smart atoms, their stomach extracts far more from their food.</description>
		<iconPath>UI/Icons/Genes/Gene_StrongStomach</iconPath>
		<biostatMet>6</biostatMet>
		<biostatCpx>12</biostatCpx>
		<biostatArc>3</biostatArc>
