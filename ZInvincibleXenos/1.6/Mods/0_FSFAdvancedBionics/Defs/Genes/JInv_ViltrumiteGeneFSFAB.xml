<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<GeneDef>
		<defName>JInv_VFistGene</defName>
		<label>Mighty Fists</label>
 		<displayCategory>Violence</displayCategory>
		<description>Carriers of this gene have durable, mighty fists that can be more useful in combat than most weapons.\n\n(Slightly better than a normal quality monosword)</description>
		<iconPath>UI/Icons/Genes/Gene_StrongMeleeDamage</iconPath>
		<biostatMet>-3</biostatMet>
		<biostatCpx>4</biostatCpx>
		<displayOrderInCategory>42.35</displayOrderInCategory>
		<marketValueFactor>5</marketValueFactor>
		<minAgeActive>13</minAgeActive>
		<prerequisite>JInv_VSmartGene</prerequisite>
		<modExtensions>
			<li Class="VEF.Genes.GeneExtension">
				<hediffsToBodyParts>
					<li>
						<hediff>JInvFistHediff</hediff>
						<bodyparts>
							<li>Hand</li>
							<li>Hand</li>
						</bodyparts>
					</li>
				</hediffsToBodyParts>
				<hediffToWholeBody>JInvFistGiverHediff</hediffToWholeBody>
			</li>
		</modExtensions>
	</GeneDef>

