	<GeneDef>
		<defName>JInv_VDrugsGene</defName>
		<label>Smart Neural Maintainance</label>
 		<displayCategory>ResistanceAndWeakness</displayCategory>
		<description>Smart atoms help maintain brain function and efficiency despite any damage and prevent drug addictions, but also prevent consciousness gain.</description>
		<iconPath>UI/Icons/Genes/Gene_Tough</iconPath>
		<biostatMet>2</biostatMet>
		<biostatCpx>4</biostatCpx>
		<biostatArc>1</biostatArc>
		<displayOrderInCategory>12.31</displayOrderInCategory>
		<marketValueFactor>1.5</marketValueFactor>
		<minAgeActive>13</minAgeActive>
		<capMods>
			<li>
				<capacity>BloodFiltration</capacity>
				<offset>0.5</offset>
			</li>
		</capMods>
		<modExtensions>
			<li Class="VEF.Genes.GeneExtension">				
				<hediffToWholeBody>JInvDrugImmunityHediff</hediffToWholeBody>
			</li>
		</modExtensions>
