		<iconPath>UI/Icons/Genes/Gene_Breathless</iconPath>
		<biostatCpx>2</biostatCpx>
		<biostatArc>1</biostatArc>
		<displayOrderInCategory>20.1</displayOrderInCategory>
		<immuneToVacuumBurns>true</immuneToVacuumBurns>
		<immuneToToxGasExposure>true</immuneToToxGasExposure>
		<capMods>
			<li>
				<capacity>Breathing</capacity>
				<offset>0.5</offset>
			</li>
		</capMods>
		<statOffsets>
			<VacuumResistance>0.99</VacuumResistance>
		</statOffsets>
		<hediffGiversCannotGive>
			<li>Asthma</li>
		</hediffGiversCannotGive>
		<marketValueFactor>1.5</marketValueFactor>
		<minAgeActive>13</minAgeActive>
		<exclusionTags>
			<li>VacuumResistance</li>
		</exclusionTags>
	</GeneDef>
</Defs>
