	<!--===================== Imperial civilians =========================-->

	<PawnKindDef Name="ViltrumCommonerBase" Abstract="True">
		<specificApparelRequirements>
			<li>
				<colorGenerator Class="ColorGenerator_Options">
					<options>
						<li>
							<only>(0.9, 0.9, 0.9)</only>
						</li>
					</options>
				</colorGenerator>
			</li>
			<li>
				<bodyPartGroup>UpperHead</bodyPartGroup>
				<stuff>Hyperweave</stuff>
			</li>
			<li>
				<bodyPartGroup>Torso</bodyPartGroup>
				<stuff>Hyperweave</stuff>
			</li>
			<li>
				<bodyPartGroup>Legs</bodyPartGroup>
				<stuff>Hyperweave</stuff>
			</li>
		</specificApparelRequirements>
	</PawnKindDef>

	<PawnKindDef ParentName="ViltrumCommonerBase">
		<defName>Viltrum_Common_Lodger</defName>
		<label>viltrum citizen</label>
		<race>Human</race>
		<defaultFactionDef>ViltrumEmpire</defaultFactionDef>
		<titleSelectOne>
			<li>Vilt_Peon</li>
			<li>Vilt_Underling</li>
			<li>Vilt_Servant</li>
			<li>Vilt_Citizen</li>
		</titleSelectOne>
		<maxGenerationAge>65</maxGenerationAge>
		<combatPower>30</combatPower>
		<backstoryFiltersOverride>
			<li>
				<categories>
					<li>ImperialCommon</li>
					<li>ImperialFighter</li>
					<li>Offworld</li>
					<li>VGeneric</li>
					<li>Outlander</li>
					<li>Outsider</li>
				</categories>
			</li>
		</backstoryFiltersOverride>
		<backstoryCryptosleepCommonality>0.08</backstoryCryptosleepCommonality>
		<isFighter>false</isFighter>
		<apparelTags>
			<li>IndustrialBasic</li>
			<li>SpacerMilitary</li>
		</apparelTags>
		<apparelMoney>400~2000</apparelMoney>
		<gearHealthRange>1~1</gearHealthRange>
		<apparelAllowHeadgearChance>1</apparelAllowHeadgearChance>
		<techHediffsMoney>1000~2000</techHediffsMoney>
