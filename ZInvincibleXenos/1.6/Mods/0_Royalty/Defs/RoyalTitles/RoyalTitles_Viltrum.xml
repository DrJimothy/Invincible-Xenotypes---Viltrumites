      <li>ViltrumTitle</li>
    </tags>
    <awardThought>GainedTitle</awardThought>
    <lostThought>LostTitle</lostThought>
  </RoyalTitleDef>

  <RoyalTitleDef ParentName="BaseViltrumTitle">
    <defName>Vilt_Peon</defName>
