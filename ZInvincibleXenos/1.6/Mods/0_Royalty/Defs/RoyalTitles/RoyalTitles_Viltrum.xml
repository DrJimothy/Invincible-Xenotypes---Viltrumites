    </throneRoomRequirements>
    <grantedAbilities><li>Speech</li></grantedAbilities>
    <speechCooldown>900000</speechCooldown>
    <awardWorkerClass>RoyalTitleAwardWorker_Instant</awardWorkerClass>
  </RoyalTitleDef>

