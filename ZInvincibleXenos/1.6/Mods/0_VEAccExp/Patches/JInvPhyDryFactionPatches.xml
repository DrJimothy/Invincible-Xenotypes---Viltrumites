<?xml version="1.0" encoding="utf-8" ?>
<Patch>

<!-- Viltrumite -->
<Operation Class="PatchOperationAdd">
    <xpath>Defs/FactionDef[defName="ViltrumEmpire"]/pawnGroupMakers</xpath>
    <value>
      <li>
        <!-- Dryad Attack -->
        <kindDef>Combat</kindDef>
        <commonality>1</commonality>
        <options>
          <Vilgrunt_Mercenary_Sacrifice>1</Vilgrunt_Mercenary_Sacrifice>
        </options>
      </li>
      <li>
        <!-- Dryad Attack plus Viltrumite -->
        <kindDef>Combat</kindDef>
        <commonality>1</commonality>
        <options>
          <Viltrumite_Fighter_Simple>1</Viltrumite_Fighter_Simple>
          <Vilgrunt_Mercenary_Sacrifice>4</Vilgrunt_Mercenary_Sacrifice>
        </options>
      </li>
    </value>
</Operation>

</Patch>