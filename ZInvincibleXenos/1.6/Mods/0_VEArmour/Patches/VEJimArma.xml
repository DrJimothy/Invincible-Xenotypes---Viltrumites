<?xml version="1.0" encoding="utf-8"?>
<Patch>

<!-- Giving shotguns a shotgun-specific tag... they should really have one already -->
<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="VAE_Apparel_Gambeson"]/apparel/tags</xpath>
		<value>
			<li>J_ClothUnderArm</li>
		</value>
</Operation>
<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="VAE_Handwear_MarineGloves"]/apparel/tags</xpath>
		<value>
			<li>SpacerHeavy</li>
		</value>
</Operation>
<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="VAE_Footwear_MarineBoots"]/apparel/tags</xpath>
		<value>
			<li>SpacerHeavy</li>
		</value>
</Operation>
<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="VAE_Headgear_HeavyMarineHelmet"]/apparel/tags</xpath>
		<value>
			<li>SpacerHeavy</li>
		</value>
</Operation>
<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="VAE_Apparel_HeavyMarineArmor"]/apparel/tags</xpath>
		<value>
			<li>SpacerHeavy</li>
		</value>
</Operation>

<!-- Making vilgrunt heavies... heavier -->
<Operation Class="PatchOperationReplace">
		<xpath>Defs/PawnKindDef[defName="Viltrum_Fighter_CataphractRanged"]/apparelRequired</xpath>
		<value>
			<apparelRequired>
				<li MayRequire="VanillaExpanded.VAEAccessories">VAEA_Apparel_RangedShieldBelt</li>
				<li>VAE_Apparel_HeavyMarineArmor</li>
				<li>VAE_Headgear_HeavyMarineHelmet</li>
			</apparelRequired>
		</value>
</Operation>

</Patch>