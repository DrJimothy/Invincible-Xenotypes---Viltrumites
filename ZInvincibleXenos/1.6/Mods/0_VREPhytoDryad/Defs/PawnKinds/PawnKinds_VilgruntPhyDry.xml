        <VRE_Gauranlenkin>0.2</VRE_Gauranlenkin>
        <VRE_Animakin MayRequire="Ludeon.RimWorld.Royalty">0.2</VRE_Animakin>
        <ArcheanKin MayRequire="dustydinoface.Archeankin">0.2</ArcheanKin>
      </xenotypeChances>
    </xenotypeSet>
