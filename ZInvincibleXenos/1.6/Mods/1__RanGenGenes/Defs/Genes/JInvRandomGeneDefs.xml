	<GeneDef ParentName="HALI_RandomGeneticsBase">
		<defName>HALIJInv_RandomHealing</defName>
		<label>gamble healing</label>
		<description>Carriers of this gene have random healing. This includes reduction. Chance to get nothing.</description>
		<displayOrderInCategory>10</displayOrderInCategory>
		<modExtensions>
			<li Class="HALI_RandomGenetics.Gene_Filtered">
				<filterList>
					<li>
						<exclusionTags>
							<li>WoundHealingRate</li>
						</exclusionTags>
						<filler>4</filler>
						<filler>2</filler>
					</li>
				</filterList>
			</li>
		</modExtensions>
	</GeneDef>

