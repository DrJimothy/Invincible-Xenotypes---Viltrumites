	<GeneDef ParentName="HALI_RandomGeneticsBase">
		<defName>HALIJInv_RandomAnyTail</defName>
		<label>gamble unlikely tail</label>
		<description>Might generate any random tail, but unlikely.</description>
		<displayOrderInCategory>10</displayOrderInCategory>
		<modExtensions>
			<li Class="HALI_RandomGenetics.Gene_Filtered">
				<filterList>
					<li>
						<exclusionTags>
							<li>Tail</li>
						</exclusionTags>
						<excluded>
							<!--Excluding this tail because it can automatically kill male pawns-->
							<li MayRequire="fs.reviaracebiotech">ReviaTail</li>
							<!--Use the exclusionTags for non tail-->
							<!--use a large amount of exclusionTags-->
							<li MayRequire="emitbreaker.mim.wh40k.ch.cd">EMCD_Violence_LordofChange</li>
							<li MayRequire="emitbreaker.mim.wh40k.ch.cd">EMCD_Violence_Horror</li>
							<li MayRequire="emitbreaker.mim.wh40k.ch.cd">EMCD_Violence_Changecaster</li>
							<li MayRequire="emitbreaker.mim.wh40k.ch.cd">EMCD_Violence_Changeling</li>
							<li MayRequire="emitbreaker.mim.wh40k.ch.cd">EMCD_Violence_Flamer</li>
							<li MayRequire="emitbreaker.mim.wh40k.nc.core">EMNC_Biotransference</li>
							<li MayRequire="emitbreaker.mim.wh40k.gc.core">EMGC_Gene_PurestrainGenestealer</li>
							<li MayRequire="emitbreaker.mim.wh40k.gc.core">EMGC_Gene_Patriarch</li>
						</excluded>
						<filler>20</filler>
					</li>
				</filterList>
			</li>
		</modExtensions>
	</GeneDef>

	<GeneDef ParentName="HALI_RandomGeneticsBase">
		<defName>HALIJInv_RandomHairColor</defName>
		<label>gamble hair color</label>
		<description>might generate a random hair color for the carrier. Might not.</description>
		<iconPath>UI/Icons/Genes/RG_MultiHairColors</iconPath>
		<displayCategory>Cosmetic_Hair</displayCategory>
		<displayOrderInCategory>452</displayOrderInCategory>
		<modExtensions>
			<li Class="HALI_RandomGenetics.Gene_Filtered">
				<filterList>
					<li>
						<exclusionTags>
							<li>HairColor</li>
						</exclusionTags>
						<minMetabolism>0</minMetabolism>
						<excluded>
							<!--Does more than just changing hair color-->
							<li MayRequire="resplice.xotr.core,Ludeon.Rimworld.Anomaly">RS_VoidTouched</li>
						</excluded>
						<filler>20</filler>
					</li>
				</filterList>
			</li>
		</modExtensions>
	</GeneDef>
	
