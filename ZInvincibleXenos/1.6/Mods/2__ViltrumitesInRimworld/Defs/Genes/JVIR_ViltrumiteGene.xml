	<GeneDef>
		<defName>JInv_VSkinMicro</defName>
		<label>Micro-Carbon Skin</label>
 		<displayCategory>Pain</displayCategory>
		<description>Carriers of this gene have a hyper-dense, fire-proof carbon latice in their skin. It resists cutting incredibly well, and absorbs heat, but doesn't absorb shock and so is useless against blunt impacts.</description>
		<iconPath>UI/Icons/Genes/BattleBeastresilient</iconPath>
		<biostatMet>-6</biostatMet>
		<biostatCpx>4</biostatCpx>
		<displayOrderInCategory>12.31</displayOrderInCategory>
		<statOffsets>
			<ArmorRating_Sharp>1.5</ArmorRating_Sharp>
			<ArmorRating_Heat>1</ArmorRating_Heat>
		</statOffsets>
		<statFactors>
			<Flammability>0.01</Flammability>
		</statFactors>
		<immuneToVacuumBurns MayRequire="Ludeon.RimWorld.Odyssey">true</immuneToVacuumBurns>
		<marketValueFactor>2</marketValueFactor>
		<minAgeActive>13</minAgeActive>
