<?xml version="1.0" encoding="utf-8" ?>
<Patch>
  
    <!--Make Imperio Viltrumites have more varied backstories-->
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/PawnKindDef[defName="ViltrumiteEmpire_Weak"]/backstoryFilters</xpath>
        <value>
          <backstoryFilters>
            <li>
              <categories>
                <li>ImperioViltrumita</li>
                <li>ViltrumGarbage</li>
                <li>ViltrumChild</li>
              </categories>
            </li>
          </backstoryFilters>
        </value>
    </Operation>

