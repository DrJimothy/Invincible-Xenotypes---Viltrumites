<?xml version="1.0" encoding="utf-8"?>
<Patch>

<!-- WeakViltrumite -->
<Operation Class="PatchOperationAdd">
		<xpath>Defs/PawnKindDef[defName="Viltrumite_Fighter_Garbage"]</xpath>
		<value>
			<xenotypeSet Inherit="False">
				<xenotypeChances>
					<WeakViltrumite>0.8</WeakViltrumite>
					<Jim_Viltrumite>0.3</Jim_Viltrumite>
				</xenotypeChances>
			</xenotypeSet>
		</value>
</Operation>
<Operation Class="PatchOperationAdd">
