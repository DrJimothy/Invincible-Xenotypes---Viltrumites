	<RulePackDef>
		<defName>NamerPersonAngstromMale</defName>
		<include>
			<li>AngstromNameUtility</li>
		</include>
		<rulePack>
			<rulesStrings>
				<li>r_name->[AngstromNameFirstMale] [AngstromNameLast]</li>
			</rulesStrings>
		</rulePack>
	</RulePackDef>

	<RulePackDef>
		<defName>NamerPersonAngstromFemale</defName>
		<include>
			<li>AngstromNameUtility</li>
		</include>
		<rulePack>
			<rulesStrings>
				<li>r_name->[AngstromNameFirstFemale] [AngstromNameLast]</li>
			</rulesStrings>
		</rulePack>
	</RulePackDef>

</Defs>