	<!-- Weakness -->

	<HediffDef>
		<defName>JInvNoiseWeakHediff</defName>
		<label>advanced inner ear</label>
		<description>Ah, an inner ear so advanced it lets one do loop-de-loops in the air without getting dizzy. Surely, this comes with no weaknesses nor vulnerabilities whatsoever.</description>
		<allowMothballIfLowPriorityWorldPawn>true</allowMothballIfLowPriorityWorldPawn>
		<everCurableByItem>false</everCurableByItem>
		<scenarioCanAdd>false</scenarioCanAdd>
		<isBad>false</isBad>
		<hediffClass>HediffWithComps</hediffClass>
		<stages>
			<li>
				<capMods>
					<li>
						<capacity>Hearing</capacity>
						<postFactor>1.25</postFactor>
					</li>
				</capMods>
			</li>
		</stages>
		<comps>
			<li Class="HediffCompProperties_ReactOnDamage">
				<damageDefIncoming>EMP</damageDefIncoming>
				<createHediff>JInvNoiseHurtHediff</createHediff>
			</li>
		</comps>
	</HediffDef>

