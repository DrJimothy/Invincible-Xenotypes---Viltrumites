<?xml version="1.0" encoding="utf-8"?>
<Patch>

<!-- Make Marines feel Mariney -->
<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Gun_ChargeRifle"]/weaponTags</xpath>
		<value>
			<li>JimPew_Marine</li>
		</value>
</Operation>

<!-- Giving shotguns a shotgun-specific tag... they should really have one already -->
<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Gun_PumpShotgun"]/weaponTags</xpath>
		<value>
			<li>JimPew_Shotgun</li>
		</value>
</Operation>
<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Gun_ChainShotgun"]/weaponTags</xpath>
		<value>
			<li>JimPew_Shotgun</li>
			<li>JimPew_StrongShotgun</li>
		</value>
</Operation>

<!-- Mighty sniper rifle -->
<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Gun_ChargeLance"]/weaponTags</xpath>
		<value>
			<li>JimPew_SniperStrong</li>
		</value>
</Operation>

