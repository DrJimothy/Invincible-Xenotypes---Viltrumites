<!-- Angstrom's Pewpew being an EMP launcher -->
<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Gun_EmpLauncher"]/weaponTags</xpath>
		<value>
			<li>JimPew_Angstrom</li>
		</value>
</Operation>

